# CarbonSense Environment Configuration

# Copy this file to .env and update the values for your environment

# === Database Configuration ===
DATABASE_URL=postgresql://username:password@localhost:5432/carbonsense
REDIS_URL=redis://localhost:6379

# === Authentication ===
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === API Keys ===
# Google Maps Platform
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Weather and Air Quality
OPENWEATHER_API_KEY=your-openweather-api-key
IQAIR_API_KEY=your-iqair-api-key

# Satellite Data
NASA_API_KEY=your-nasa-api-key
ESA_SENTINEL_API_KEY=your-esa-api-key

# === External Services ===
# Carbon Credit Providers
GOLD_STANDARD_API_KEY=your-gold-standard-api-key
VCS_API_KEY=your-vcs-api-key

# Banking/Financial APIs (for spending analysis)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# === Email Configuration ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# === Cloud Storage ===
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=carbonsense-assets
AWS_REGION=us-east-1

# === Analytics ===
MIXPANEL_PROJECT_TOKEN=your-mixpanel-token
GOOGLE_ANALYTICS_ID=your-ga-id

# === Push Notifications ===
FCM_SERVER_KEY=your-fcm-server-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id

# === Machine Learning ===
ML_MODEL_PATH=./ml/models
HUGGINGFACE_API_KEY=your-huggingface-api-key

# === Corporate Features ===
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# === Development ===
DEBUG=true
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:3000", "http://localhost:19006"]

# === Production Settings ===
# DOMAIN=https://api.carbonsense.com
# CORS_ORIGINS=["https://carbonsense.com", "https://app.carbonsense.com"]
# DEBUG=false